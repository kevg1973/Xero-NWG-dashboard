# Server
PORT=8080
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Linnworks (EU region)
LINNWORKS_APPLICATION_ID=
LINNWORKS_APPLICATION_SECRET=
LINNWORKS_TOKEN=

# Cron — set TRUE on Railway to enable scheduled sync, leave blank locally
ENABLE_CRON=false
SYNC_CRON_EXPRESSION=0 17 * * *
SYNC_CRON_TZ=Europe/London
