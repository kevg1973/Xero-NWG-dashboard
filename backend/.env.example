# Server
PORT=8080
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Linnworks (EU region)
LINNWORKS_APPLICATION_ID=
LINNWORKS_APPLICATION_SECRET=
LINNWORKS_TOKEN=

# Cron — set TRUE on Railway to enable scheduled sync, leave blank locally
ENABLE_CRON=false
SYNC_CRON_EXPRESSION=0 17 * * *
SYNC_CRON_TZ=Europe/London

# Xero OAuth — register an app in the Xero developer portal
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://xero-nwg-dashboard-production.up.railway.app/api/xero/callback
# 32-byte AES-256-GCM key, base64-encoded. Generate: openssl rand -base64 32
XERO_ENCRYPTION_KEY=
# Where /api/xero/callback redirects after auth completes (production frontend or localhost:5173)
XERO_FRONTEND_URL=https://dashboard.northwestguitars.co.uk
